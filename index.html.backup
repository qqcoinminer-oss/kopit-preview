<!-- ══════════════════════════════════════
     HOW KOPIT WORKS
══════════════════════════════════════ -->
<section class="how-sec" id="how-it-works">
  <div class="how-inner">
    <div class="how-label-wrap">
      <div class="how-label-line"></div>
      <div class="how-label">HOW KOPIT WORKS</div>
    </div>
    <h2 class="how-heading">Satu Koperasi. <span class="gold">Every Opportunity.</span></h2>
    <p class="how-sub">From mega-projects to government tenders to private clients — the cooperative model adapts to every scale and every sector.</p>

    <div class="how-steps-wrap">
      <div class="steps-grid">

        <div class="step-item">
          <div class="step-circle"><span class="step-num">1</span></div>
          <div class="step-label">Step One</div>
          <div class="step-title">Opportunity Identified</div>
          <p class="step-body">Member-originated. Government tender. Private client. Every path leads to KOPIT.</p>
        </div>

        <div class="step-item">
          <div class="step-circle"><span class="step-num">2</span></div>
          <div class="step-label">Step Two</div>
          <div class="step-title">Divisions Assemble</div>
          <p class="step-body">The right divisions activate. One leads. Others contribute. Always collaborative.</p>
        </div>

        <div class="step-item">
          <div class="step-circle"><span class="step-num">3</span></div>
          <div class="step-label">Step Three</div>
          <div class="step-title">Cooperative Delivers</div>
          <p class="step-body">KOPIT delivers at institutional standard. Member-led, cooperative-backed, professionally executed.</p>
        </div>

        <div class="step-item">
          <div class="step-circle"><span class="step-num">4</span></div>
          <div class="step-label">Step Four</div>
          <div class="step-title">Wealth Returns</div>
          <p class="step-body">Project earnings flow back through cooperative dividends. Every member benefits.</p>
        </div>

      </div>
    </div>

    <div class="how-closing">
      <p class="how-quote">Whatever the size. <span class="gold">Whatever the sector.</span><span class="break">Satu Koperasi. Endless opportunities.</span></p>
      <a href="projects.html" class="how-cta-btn">View Our Projects →</a>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════
     MEMBERSHIP TEASER
══════════════════════════════════════ -->
<section class="memb-teaser-sec" id="membership-teaser">
  <div class="memb-teaser-inner">

    <div class="memb-lbl-wrap">
      <div class="memb-lbl-line"></div>
      <div class="memb-lbl">MEMBERSHIP</div>
    </div>
    <h2 class="headline-top hero-size" style="text-align:center;">Membership Is</h2>
    <h2 class="headline-bottom hero-size" style="text-align:center;margin-bottom:14px;">By Invitation.</h2>
    <p class="memb-sub">Seven tiers. Curated by the cooperative. The Board of Directors reviews every application.</p>

    <!-- GLOBE STAGE -->
    <div class="globe-stage">
      <div class="globe-inner" id="globeInner">

        <!-- CARD 1: BOD — Board of Directors -->
        <div class="globe-card" data-idx="0" style="background:linear-gradient(135deg,#080808 0%,#121212 22%,#1a1400 42%,#3a2c08 49%,#5a4410 50%,#3a2c08 51%,#1a1400 58%,#121212 78%,#080808 100%);border:1px solid rgba(201,168,76,0.65);box-shadow:0 24px 60px rgba(0,0,0,0.65),0 0 30px rgba(255,228,150,0.35);">
          <svg style="position:absolute;inset:0;width:100%;height:100%;opacity:0.05" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="guillo1" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse"><circle cx="11" cy="11" r="10" fill="none" stroke="#f0d878" stroke-width="0.4"/><circle cx="0" cy="11" r="10" fill="none" stroke="#f0d878" stroke-width="0.4"/><circle cx="22" cy="11" r="10" fill="none" stroke="#f0d878" stroke-width="0.4"/><circle cx="11" cy="0" r="10" fill="none" stroke="#f0d878" stroke-width="0.4"/><circle cx="11" cy="22" r="10" fill="none" stroke="#f0d878" stroke-width="0.4"/></pattern></defs><rect width="100%" height="100%" fill="url(#guillo1)"/></svg>
